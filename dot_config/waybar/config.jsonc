{
    "position": "top",
    "margin-top": 15,
    "modules-left": [
      
    ],
    "modules-center": [
        "clock",
        "hyprland/workspaces",
        "custom/weather",
        "pulseaudio",
        "network",
        "battery",
        "tray",
        "custom/notification"
    ],
    "modules-right": [
      
    ],
    "clock": {
        "format": "{:%Y-%m-%d %H:%M}",
        "tooltip-format": "{:%A, %d. %B %Y}"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "persistent-workspaces": {
            "*": 5
        }
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": {
            "default": [
                "",
                "",
                ""
            ]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "interface": "wlan0",
        "format-wifi": "  {essid}",
        "format-ethernet": "󰈀  Ethernet",
        "format-disconnected": "󰤭  Disconnected",
        "tooltip-format-wifi": "{ifname}: {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected"
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": [
            "󰁺",
            "󰁻",
            "󰁼",
            "󰁽",
            "󰁾",
            "󰁿",
            "󰂀",
            "󰂁",
            "󰂂",
            "󰁹"
        ]
    },
    "custom/weather": {
        "exec": "/home/matt/.config/waybar/scripts/weather.sh",
        "interval": 900,
        "return-type": "json",
        "format": "{}",
        "tooltip": true
    },
    "custom/notification": {
        "tooltip": false,
        "format": "󰂚",
        "on-click": "swaync-client -t",
        "exec": "swaync-client -swb",
        "return-type": "json",
        "escape": true
    }
}